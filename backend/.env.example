PORT=4000
NODE_ENV=development

# Redis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DB=

# SMS (Fast2SMS)
FAST2SMS_API_KEY=
FAST2SMS_ENTITY_ID=
FAST2SMS_DEFAULT_SENDER_ID=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=

# OTP DLT — global master switch (default false; per-app dltEnabled in otp-mappings.json)
OTP_DLT_ENABLED=false

# Authentication — JSON map of appId to apiKey
APP_CREDENTIALS_JSON={"my-app":"your-secret-key"}
