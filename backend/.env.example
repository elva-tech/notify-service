PORT=4000
NODE_ENV=development

# Redis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DB=

# SMS (Fast2SMS)
FAST2SMS_API_KEY=
FAST2SMS_ENTITY_ID=
FAST2SMS_DEFAULT_SENDER_ID=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=

# Integrations onboarding (Phase 4)
ADMIN_NOTIFY_EMAIL=ops@example.com
OPS_ADMIN_TOKEN=change-me-in-production
# Public frontend URL for onboarding emails (status links, docs links)
# Development:
PLATFORM_PUBLIC_URL=http://localhost:3000
# Production:
# PLATFORM_PUBLIC_URL=https://notify.elvatech.in
# appId key used in approval emails (defaults to ELVA_NOTIFY, else first APP_CREDENTIALS_JSON entry)
# INTEGRATION_APP_ID=ELVA_NOTIFY

# OTP DLT — global master switch (default false; per-app dltEnabled in otp-mappings.json)
OTP_DLT_ENABLED=false

# Authentication — shared platform appId → apiKey (one pair for all integrators)
APP_CREDENTIALS_JSON={"ELVA_NOTIFY":"shared-platform-api-key"}
