{
  "name": "elva-notify-platform",
  "version": "1.0.0",
  "private": true,
  "description": "ELVA Notify Platform — backend API and documentation frontend",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "frontend:manifest": "npm --prefix frontend run generate:manifest",
    "frontend:openapi": "npm --prefix frontend run generate:openapi",
    "frontend:business": "npm --prefix frontend run generate:business",
    "openapi:validate": "npm --prefix frontend run openapi:validate",
    "otp:health": "node backend/scripts/generate-otp-health-snapshot.mjs",
    "business:health": "node backend/scripts/generate-business-health-snapshot.mjs",
    "validate:businesses": "node backend/scripts/validate-business-configs.mjs",
    "validate:brand-registry": "node backend/scripts/validate-brand-registry.mjs",
    "validate:enandi-dlt": "node backend/scripts/validate-enandi-notify-local.mjs",
    "test:enandi-dlt-live": "node backend/scripts/live-enandi-dlt-test.mjs",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
