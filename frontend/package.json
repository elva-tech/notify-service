{
  "name": "elva-notify-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/generate-manifest.mjs && node scripts/generate-openapi-manifest.mjs",
    "predev:full": "node scripts/generate-manifest.mjs && node scripts/generate-openapi-manifest.mjs && node ../backend/scripts/generate-otp-health-snapshot.mjs && node ../backend/scripts/generate-business-health-snapshot.mjs",
    "dev": "next dev -p 3000",
    "dev:turbo": "next dev --turbo -p 3000",
    "dev:webpack": "next dev -p 3000",
    "dev:clean": "npm run clean && npm run dev",
    "dev:reset": "node scripts/reset-dev.mjs",
    "prebuild": "node scripts/generate-manifest.mjs && node scripts/generate-openapi-manifest.mjs",
    "build": "next build",
    "build:standalone": "node scripts/build-standalone.mjs",
    "start": "next start -p 3000",
    "lint": "next lint",
    "generate:manifest": "node scripts/generate-manifest.mjs",
    "generate:openapi": "node scripts/generate-openapi-manifest.mjs",
    "openapi:validate": "node scripts/validate-openapi.mjs",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.475.0",
    "mermaid": "^11.4.1",
    "next": "^15.1.6",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "shiki": "^1.26.1",
    "tailwind-merge": "^2.6.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "@apidevtools/swagger-parser": "^10.1.1"
  }
}
