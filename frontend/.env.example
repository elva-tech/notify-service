# Optional: prefix all routes/assets when mounted under a subpath (e.g. notify.elvatech.in/docs)
# Leave empty for docs.notify.elvatech.in or local dev
NEXT_PUBLIC_BASE_PATH=

# Backend API base URL — used by playground, platform metadata, and rendered docs examples.
# Local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Production deployment:
# NEXT_PUBLIC_API_BASE_URL=https://api.notify.elvatech.in
